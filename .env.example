# =============================================================================
# KANBAN TICKET SYSTEM — Environment Variables Template
# Copy this file to .env and fill in your values. NEVER commit .env to Git.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=KanbanTicketSystem
APP_VERSION=1.0.0
API_PORT=4000
WEB_PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kanban_user:change_me_strong_password@localhost:5432/kanban_db
POSTGRES_DB=kanban_db
POSTGRES_USER=kanban_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_very_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_me_to_another_very_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (session/cache) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change_me_redis_password
REDIS_PORT=6379

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ── Email (optional — for notifications) ─────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=change_me_smtp_password
EMAIL_FROM=KanbanSystem <noreply@example.com>

# ── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=./uploads

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
SESSION_SECRET=change_me_session_secret_at_least_32_chars
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ── Production overrides (set in prod only) ───────────────────────────────────
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=strict
# NODE_ENV=production
